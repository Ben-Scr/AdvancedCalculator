<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:AdvancedCalculator.Controls">
    <Style TargetType="{x:Type Window}">
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>

    <Style TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>

    <Style TargetType="{x:Type controls:AnimatedButton}">
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="NormalColor" Value="{DynamicResource SurfaceRaisedColor}" />
        <Setter Property="HoverColor" Value="{DynamicResource SurfaceHoverColor}" />
        <Setter Property="PressedColor" Value="{DynamicResource SurfacePressedColor}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:AnimatedButton}">
                    <Border x:Name="PART_BackgroundBorder"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            SnapsToDevicePixels="True"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="PART_ScaleTransform"
                                            ScaleX="1"
                                            ScaleY="1" />
                        </Border.RenderTransform>
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Margin="{TemplateBinding Padding}"
                                          RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="PART_BackgroundBorder" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ToolbarButtonStyle"
           TargetType="{x:Type controls:AnimatedButton}"
           BasedOn="{StaticResource {x:Type controls:AnimatedButton}}">
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Width" Value="34" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="NormalColor" Value="{DynamicResource SurfaceColor}" />
        <Setter Property="HoverColor" Value="{DynamicResource SurfaceHoverColor}" />
        <Setter Property="PressedColor" Value="{DynamicResource SurfacePressedColor}" />
    </Style>

    <Style x:Key="WindowCommandButtonStyle"
           TargetType="{x:Type controls:AnimatedButton}"
           BasedOn="{StaticResource ToolbarButtonStyle}">
        <Setter Property="Width" Value="42" />
    </Style>

    <Style x:Key="CloseWindowButtonStyle"
           TargetType="{x:Type controls:AnimatedButton}"
           BasedOn="{StaticResource WindowCommandButtonStyle}">
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
        <Setter Property="NormalColor" Value="{DynamicResource DangerColor}" />
        <Setter Property="HoverColor" Value="{DynamicResource DangerHoverColor}" />
        <Setter Property="PressedColor" Value="{DynamicResource DangerPressedColor}" />
    </Style>

    <Style x:Key="CalculatorKeyButtonStyle"
           TargetType="{x:Type controls:AnimatedButton}"
           BasedOn="{StaticResource {x:Type controls:AnimatedButton}}">
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="MinHeight" Value="52" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsAccent}" Value="True">
                <Setter Property="Foreground" Value="White" />
                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                <Setter Property="NormalColor" Value="{DynamicResource AccentColor}" />
                <Setter Property="HoverColor" Value="{DynamicResource AccentHoverColor}" />
                <Setter Property="PressedColor" Value="{DynamicResource AccentPressedColor}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="HistoryEntryButtonStyle"
           TargetType="{x:Type controls:AnimatedButton}"
           BasedOn="{StaticResource {x:Type controls:AnimatedButton}}">
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="14,12" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="NormalColor" Value="{DynamicResource SurfaceRaisedColor}" />
        <Setter Property="HoverColor" Value="{DynamicResource SurfaceHoverColor}" />
        <Setter Property="PressedColor" Value="{DynamicResource SurfacePressedColor}" />
    </Style>

    <Style x:Key="DangerIconButtonStyle"
           TargetType="{x:Type controls:AnimatedButton}"
           BasedOn="{StaticResource ToolbarButtonStyle}">
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Width" Value="36" />
        <Setter Property="Height" Value="36" />
        <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
        <Setter Property="NormalColor" Value="{DynamicResource DangerColor}" />
        <Setter Property="HoverColor" Value="{DynamicResource DangerHoverColor}" />
        <Setter Property="PressedColor" Value="{DynamicResource DangerPressedColor}" />
    </Style>

    <Style x:Key="FlatSidebarButtonStyle"
           TargetType="{x:Type controls:AnimatedButton}"
           BasedOn="{StaticResource ToolbarButtonStyle}">
        <Setter Property="Width" Value="Auto" />
        <Setter Property="Height" Value="36" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="NormalColor" Value="{DynamicResource SurfaceRaisedColor}" />
        <Setter Property="HoverColor" Value="{DynamicResource SurfaceHoverColor}" />
        <Setter Property="PressedColor" Value="{DynamicResource SurfacePressedColor}" />
    </Style>

    <Style x:Key="ExpressionTextBoxStyle" TargetType="{x:Type TextBox}">
        <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="SelectionBrush" Value="{DynamicResource AccentBrush}" />
        <Setter Property="CaretBrush" Value="{DynamicResource TextBrush}" />
    </Style>
</ResourceDictionary>
