<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="AppBackgroundColor">#0D1117</Color>
    <Color x:Key="SurfaceColor">#161B22</Color>
    <Color x:Key="SurfaceRaisedColor">#21262D</Color>
    <Color x:Key="SurfaceHoverColor">#30363D</Color>
    <Color x:Key="SurfacePressedColor">#1B2129</Color>
    <Color x:Key="BorderColor">#30363D</Color>
    <Color x:Key="AccentColor">#238636</Color>
    <Color x:Key="AccentHoverColor">#2EA043</Color>
    <Color x:Key="AccentPressedColor">#1B6E2B</Color>
    <Color x:Key="DangerColor">#DA3633</Color>
    <Color x:Key="DangerHoverColor">#F85149</Color>
    <Color x:Key="DangerPressedColor">#B62324</Color>
    <Color x:Key="TextColor">#C9D1D9</Color>
    <Color x:Key="MutedTextColor">#8B949E</Color>
    <Color x:Key="ResultColor">#F0F6FC</Color>
    <Color x:Key="SidebarShadowColor">#59000000</Color>
    <Color x:Key="ErrorBackgroundColor">#2D1117</Color>
    <Color x:Key="ErrorAccentColor">#F85149</Color>

    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource AppBackgroundColor}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="SurfaceRaisedBrush" Color="{StaticResource SurfaceRaisedColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="{StaticResource MutedTextColor}" />
    <SolidColorBrush x:Key="ResultBrush" Color="{StaticResource ResultColor}" />
    <SolidColorBrush x:Key="ErrorBackgroundBrush" Color="{StaticResource ErrorBackgroundColor}" />
    <SolidColorBrush x:Key="ErrorAccentBrush" Color="{StaticResource ErrorAccentColor}" />
    <SolidColorBrush x:Key="SidebarShadowBrush" Color="{StaticResource SidebarShadowColor}" />
</ResourceDictionary>
