<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="AppBackgroundColor">#FFFFFF</Color>
    <Color x:Key="SurfaceColor">#F6F8FA</Color>
    <Color x:Key="SurfaceRaisedColor">#FFFFFF</Color>
    <Color x:Key="SurfaceHoverColor">#EAEFF5</Color>
    <Color x:Key="SurfacePressedColor">#DDE4EB</Color>
    <Color x:Key="BorderColor">#D0D7DE</Color>
    <Color x:Key="AccentColor">#1F883D</Color>
    <Color x:Key="AccentHoverColor">#2DA44E</Color>
    <Color x:Key="AccentPressedColor">#1A7F37</Color>
    <Color x:Key="DangerColor">#CF222E</Color>
    <Color x:Key="DangerHoverColor">#F85149</Color>
    <Color x:Key="DangerPressedColor">#A40E26</Color>
    <Color x:Key="TextColor">#24292F</Color>
    <Color x:Key="MutedTextColor">#57606A</Color>
    <Color x:Key="ResultColor">#24292F</Color>
    <Color x:Key="SidebarShadowColor">#26000000</Color>
    <Color x:Key="ErrorBackgroundColor">#FFF1F0</Color>
    <Color x:Key="ErrorAccentColor">#CF222E</Color>

    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource AppBackgroundColor}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="SurfaceRaisedBrush" Color="{StaticResource SurfaceRaisedColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="{StaticResource MutedTextColor}" />
    <SolidColorBrush x:Key="ResultBrush" Color="{StaticResource ResultColor}" />
    <SolidColorBrush x:Key="ErrorBackgroundBrush" Color="{StaticResource ErrorBackgroundColor}" />
    <SolidColorBrush x:Key="ErrorAccentBrush" Color="{StaticResource ErrorAccentColor}" />
    <SolidColorBrush x:Key="SidebarShadowBrush" Color="{StaticResource SidebarShadowColor}" />
</ResourceDictionary>
