<Window x:Class="BenScr.AdvancedCalculator.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:BenScr.AdvancedCalculator.Controls"
        xmlns:core="clr-namespace:BenScr.AdvancedCalculator.Core"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Advanced Calculator"
        Width="430"
        Height="760"
        MinWidth="380"
        MinHeight="520"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{DynamicResource AppBackgroundBrush}"
        Opacity="0">
    <Window.Resources>
        <DataTemplate x:Key="ConverterFieldTemplate">
            <Border Width="180"
                    Margin="0,0,12,12"
                    Padding="14"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                <StackPanel>
                    <TextBlock Text="{Binding Label}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource MutedTextBrush}" />
                    <Border Margin="0,10,0,0"
                            Background="{DynamicResource SurfaceRaisedBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10">
                        <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent"
                                 Padding="14,12"
                                 Style="{StaticResource ExpressionTextBoxStyle}" />
                    </Border>
                </StackPanel>
            </Border>
        </DataTemplate>

        <ItemsPanelTemplate x:Key="ConverterFieldItemsPanel">
            <WrapPanel />
        </ItemsPanelTemplate>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0"
                                     To="1"
                                     Duration="0:0:0.35" />
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="48"
                            CornerRadius="10"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Border Background="{DynamicResource AppBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0"
            SnapsToDevicePixels="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1">
                <Grid MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="16,0,0,0">
                        <TextBlock Text="Advanced Calculator"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="0,0,6,0"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <controls:AnimatedButton Style="{StaticResource WindowCommandButtonStyle}"
                                                 Click="Minimize_OnClick"
                                                 ToolTip="Minimize"
                                                 Content="&#xE921;" />
                        <controls:AnimatedButton x:Name="MaximizeRestoreButton"
                                                 Style="{StaticResource WindowCommandButtonStyle}"
                                                 Click="MaximizeRestore_OnClick"
                                                 Content="&#xE922;" />
                        <controls:AnimatedButton Style="{StaticResource CloseWindowButtonStyle}"
                                                 Click="Close_OnClick"
                                                 ToolTip="Close"
                                                 Content="&#xE8BB;" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Margin="20,16,20,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <controls:AnimatedButton Style="{StaticResource ToolbarSymbolButtonStyle}"
                                             Click="NavigationMenuButton_OnClick"
                                             ToolTip="Open tools"
                                             Content="&#xE700;"
                                             Tag="{Binding}">
                        <controls:AnimatedButton.ContextMenu>
                            <ContextMenu Style="{StaticResource HistoryContextMenuStyle}">
                                <MenuItem Header="Calculator"
                                          Style="{StaticResource HistoryContextMenuSectionHeaderStyle}" />
                                <MenuItem Header="Standard"
                                          Style="{StaticResource HistoryContextMenuItemStyle}"
                                          Command="{Binding PlacementTarget.Tag.OpenToolCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          CommandParameter="Calculator.Standard" />
                                <MenuItem Header="Scientific"
                                          Style="{StaticResource HistoryContextMenuItemStyle}"
                                          Command="{Binding PlacementTarget.Tag.OpenToolCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          CommandParameter="Calculator.Scientific" />
                                <Separator Style="{StaticResource HistoryContextMenuSeparatorStyle}" />
                                <MenuItem Header="Converter"
                                          Style="{StaticResource HistoryContextMenuSectionHeaderStyle}" />
                                <MenuItem Header="Number Converter"
                                          Style="{StaticResource HistoryContextMenuItemStyle}"
                                          Command="{Binding PlacementTarget.Tag.OpenToolCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          CommandParameter="Converter.Number" />
                                <MenuItem Header="Memory Converter"
                                          Style="{StaticResource HistoryContextMenuItemStyle}"
                                          Command="{Binding PlacementTarget.Tag.OpenToolCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          CommandParameter="Converter.Memory" />
                                <MenuItem Header="Weight Converter"
                                          Style="{StaticResource HistoryContextMenuItemStyle}"
                                          Command="{Binding PlacementTarget.Tag.OpenToolCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          CommandParameter="Converter.Weight" />
                                <MenuItem Header="Volume Converter"
                                          Style="{StaticResource HistoryContextMenuItemStyle}"
                                          Command="{Binding PlacementTarget.Tag.OpenToolCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          CommandParameter="Converter.Volume" />
                                <MenuItem Header="Power / Energy Converter"
                                          Style="{StaticResource HistoryContextMenuItemStyle}"
                                          Command="{Binding PlacementTarget.Tag.OpenToolCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          CommandParameter="Converter.Energy" />
                                <MenuItem Header="Length Converter"
                                          Style="{StaticResource HistoryContextMenuItemStyle}"
                                          Command="{Binding PlacementTarget.Tag.OpenToolCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          CommandParameter="Converter.Length" />
                                <Separator Style="{StaticResource HistoryContextMenuSeparatorStyle}" />
                                <MenuItem Header="Settings"
                                          Style="{StaticResource HistoryContextMenuSectionHeaderStyle}" />
                                <MenuItem Header="Settings"
                                          Style="{StaticResource HistoryContextMenuItemStyle}"
                                          Command="{Binding PlacementTarget.Tag.OpenToolCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          CommandParameter="Settings" />
                            </ContextMenu>
                        </controls:AnimatedButton.ContextMenu>
                    </controls:AnimatedButton>

                    <TextBlock Grid.Column="1"
                               Margin="14,0,14,0"
                               VerticalAlignment="Center"
                               Text="{Binding CurrentToolTitle}"
                               FontSize="15"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" />

                    <controls:AnimatedButton Grid.Column="2"
                                             Style="{StaticResource ToolbarSymbolButtonStyle}"
                                             Command="{Binding ToggleHistoryCommand}"
                                             ToolTip="Open history"
                                             Content="&#xE81C;" />
                </Grid>
            </Border>

            <Grid Grid.Row="2"
                  Margin="20,0,20,20"
                  Visibility="{Binding IsCalculatorPage, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="Expression"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Margin="0,0,0,8" />
                    <Border Background="{DynamicResource SurfaceRaisedBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="14,12">
                        <TextBox x:Name="ExpressionTextBox"
                                 Text="{Binding Expression, UpdateSourceTrigger=PropertyChanged}"
                                 HorizontalAlignment="Stretch"
                                 HorizontalContentAlignment="Stretch"
                                 Style="{StaticResource ExpressionTextBoxStyle}"
                                 core:CaretIndexBinding.Enable="True"
                                 core:CaretIndexBinding.CaretIndex="{Binding CaretIndex, Mode=TwoWay}">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter"
                                            Command="{Binding EvaluateCommand}" />
                            </TextBox.InputBindings>
                        </TextBox>
                    </Border>
                </StackPanel>

                <Border x:Name="ErrorContainer"
                        Grid.Row="1"
                        Margin="0,12,0,0"
                        Padding="12,10"
                        CornerRadius="8"
                        Background="{DynamicResource ErrorBackgroundBrush}"
                        BorderBrush="{DynamicResource ErrorAccentBrush}"
                        BorderThickness="1"
                        Visibility="Collapsed"
                        Opacity="0">
                    <Border.RenderTransform>
                        <TranslateTransform Y="-6" />
                    </Border.RenderTransform>
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{DynamicResource ErrorAccentBrush}"
                               TextWrapping="Wrap" />
                </Border>

                <Border Grid.Row="2"
                        Margin="0,16,0,18"
                        Padding="16"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12">
                    <StackPanel>
                        <TextBlock Text="Result"
                                   Foreground="{DynamicResource MutedTextBrush}" />
                        <TextBlock x:Name="ResultTextBlock"
                                   Text="{Binding Result}"
                                   Margin="0,8,0,0"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ResultBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <TextBlock Grid.Row="3"
                           Text="Keypad"
                           Margin="0,0,0,10"
                           Foreground="{DynamicResource MutedTextBrush}" />

                <Grid Grid.Row="4">
                    <ItemsControl ItemsSource="{Binding StandardKeys}"
                                  Visibility="{Binding IsStandardMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="4" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <controls:AnimatedButton Margin="4"
                                                         Content="{Binding Label}"
                                                         Command="{Binding Command}"
                                                         CommandParameter="{Binding CommandParameter}"
                                                         IsEnabled="{Binding IsEnabled}"
                                                         Style="{StaticResource CalculatorKeyButtonStyle}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <ItemsControl ItemsSource="{Binding ScientificKeys}"
                                  Visibility="{Binding IsScientificMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="5" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <controls:AnimatedButton Margin="4"
                                                         Content="{Binding Label}"
                                                         Command="{Binding Command}"
                                                         CommandParameter="{Binding CommandParameter}"
                                                         IsEnabled="{Binding IsEnabled}"
                                                         Style="{StaticResource CalculatorKeyButtonStyle}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Grid>

            <ScrollViewer Grid.Row="2"
                          Margin="20,0,20,20"
                          VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding IsConverterPage, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="Choose a converter from the menu."
                               Foreground="{DynamicResource MutedTextBrush}"
                               Visibility="{Binding IsConverterSelectionVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />

                    <StackPanel Visibility="{Binding HasActiveConverter, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Padding="16"
                                    Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <StackPanel>
                                    <TextBlock Text="From"
                                               Foreground="{DynamicResource MutedTextBrush}" />
                                    <ComboBox Margin="0,10,0,0"
                                              ItemsSource="{Binding ActiveUnitConverter.Units}"
                                              SelectedItem="{Binding ActiveUnitConverter.SourceUnit}"
                                              Style="{StaticResource FlatComboBoxStyle}" />
                                    <Border Margin="0,12,0,0"
                                            Background="{DynamicResource SurfaceRaisedBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10">
                                        <TextBox Text="{Binding ActiveUnitConverter.SourceValue, UpdateSourceTrigger=PropertyChanged}"
                                                 Padding="14,12"
                                                 Style="{StaticResource ExpressionTextBoxStyle}" />
                                    </Border>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2"
                                    Padding="16"
                                    Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <StackPanel>
                                    <TextBlock Text="To"
                                               Foreground="{DynamicResource MutedTextBrush}" />
                                    <ComboBox Margin="0,10,0,0"
                                              ItemsSource="{Binding ActiveUnitConverter.Units}"
                                              SelectedItem="{Binding ActiveUnitConverter.TargetUnit}"
                                              Style="{StaticResource FlatComboBoxStyle}" />
                                    <Border Margin="0,12,0,0"
                                            Background="{DynamicResource SurfaceRaisedBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10">
                                        <TextBox Text="{Binding ActiveUnitConverter.TargetValue, Mode=OneWay}"
                                                 IsReadOnly="True"
                                                 Padding="14,12"
                                                 Style="{StaticResource ExpressionTextBoxStyle}" />
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Margin="0,14,0,0"
                                Padding="12,10"
                                CornerRadius="8"
                                Background="{DynamicResource ErrorBackgroundBrush}"
                                BorderBrush="{DynamicResource ErrorAccentBrush}"
                                BorderThickness="1"
                                Visibility="{Binding ActiveUnitConverter.HasError, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="{Binding ActiveUnitConverter.ErrorMessage}"
                                       Foreground="{DynamicResource ErrorAccentBrush}"
                                       TextWrapping="Wrap" />
                        </Border>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer Grid.Row="2"
                          Margin="20,0,20,20"
                          VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding IsSettingsPage, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <Border Margin="0,0,0,16"
                            Padding="18"
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <StackPanel>
                            <TextBlock Text="Theme"
                                       FontSize="18"
                                       FontWeight="SemiBold" />
                            <WrapPanel Margin="0,12,0,0">
                                <controls:AnimatedButton Content="Dark"
                                                         Command="{Binding SetThemeCommand}"
                                                         CommandParameter="dark">
                                    <controls:AnimatedButton.Style>
                                        <Style TargetType="{x:Type controls:AnimatedButton}"
                                               BasedOn="{StaticResource SettingOptionButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                                    <Setter Property="Foreground" Value="White" />
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                    <Setter Property="NormalColor" Value="{DynamicResource AccentColor}" />
                                                    <Setter Property="HoverColor" Value="{DynamicResource AccentHoverColor}" />
                                                    <Setter Property="PressedColor" Value="{DynamicResource AccentPressedColor}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </controls:AnimatedButton.Style>
                                </controls:AnimatedButton>

                                <controls:AnimatedButton Margin="10,0,0,0"
                                                         Content="Light"
                                                         Command="{Binding SetThemeCommand}"
                                                         CommandParameter="light">
                                    <controls:AnimatedButton.Style>
                                        <Style TargetType="{x:Type controls:AnimatedButton}"
                                               BasedOn="{StaticResource SettingOptionButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsLightTheme}" Value="True">
                                                    <Setter Property="Foreground" Value="White" />
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                    <Setter Property="NormalColor" Value="{DynamicResource AccentColor}" />
                                                    <Setter Property="HoverColor" Value="{DynamicResource AccentHoverColor}" />
                                                    <Setter Property="PressedColor" Value="{DynamicResource AccentPressedColor}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </controls:AnimatedButton.Style>
                                </controls:AnimatedButton>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Margin="0,0,0,16"
                            Padding="18"
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <StackPanel>
                            <TextBlock Text="Live calculation"
                                       FontSize="18"
                                       FontWeight="SemiBold" />
                            <WrapPanel Margin="0,12,0,0">
                                <controls:AnimatedButton Content="On"
                                                         Command="{Binding SetLiveCalculationCommand}"
                                                         CommandParameter="True">
                                    <controls:AnimatedButton.Style>
                                        <Style TargetType="{x:Type controls:AnimatedButton}"
                                               BasedOn="{StaticResource SettingOptionButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsLiveCalculationEnabled}" Value="True">
                                                    <Setter Property="Foreground" Value="White" />
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                    <Setter Property="NormalColor" Value="{DynamicResource AccentColor}" />
                                                    <Setter Property="HoverColor" Value="{DynamicResource AccentHoverColor}" />
                                                    <Setter Property="PressedColor" Value="{DynamicResource AccentPressedColor}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </controls:AnimatedButton.Style>
                                </controls:AnimatedButton>

                                <controls:AnimatedButton Margin="10,0,0,0"
                                                         Content="Off"
                                                         Command="{Binding SetLiveCalculationCommand}"
                                                         CommandParameter="False">
                                    <controls:AnimatedButton.Style>
                                        <Style TargetType="{x:Type controls:AnimatedButton}"
                                               BasedOn="{StaticResource SettingOptionButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsLiveCalculationDisabled}" Value="True">
                                                    <Setter Property="Foreground" Value="White" />
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                    <Setter Property="NormalColor" Value="{DynamicResource AccentColor}" />
                                                    <Setter Property="HoverColor" Value="{DynamicResource AccentHoverColor}" />
                                                    <Setter Property="PressedColor" Value="{DynamicResource AccentPressedColor}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </controls:AnimatedButton.Style>
                                </controls:AnimatedButton>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Padding="18"
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <StackPanel>
                            <TextBlock Text="History"
                                       FontSize="18"
                                       FontWeight="SemiBold" />
                            <controls:AnimatedButton Margin="0,12,0,0"
                                                     Width="150"
                                                     HorizontalAlignment="Left"
                                                     Style="{StaticResource SettingOptionButtonStyle}"
                                                     Content="Clear history"
                                                     Command="{Binding ClearHistoryCommand}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Grid x:Name="HistoryOverlay"
                  Grid.Row="1"
                  Grid.RowSpan="2"
                  Background="#80000000"
                  Opacity="0"
                  Visibility="Collapsed"
                  IsHitTestVisible="False"
                  Panel.ZIndex="20"
                  MouseDown="HistoryOverlay_OnMouseDown" />

            <Border x:Name="HistorySidebar"
                    Grid.Row="1"
                    Grid.RowSpan="2"
                    Width="310"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Stretch"
                    Padding="18,18,18,20"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1,0,0,0"
                    Panel.ZIndex="21"
                    ClipToBounds="True"
                    Visibility="Collapsed"
                    IsHitTestVisible="False"
                    Opacity="0">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="HistorySidebarTransform" X="310" />
                </Border.RenderTransform>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="18"
                                      Direction="180"
                                      Opacity="0.35"
                                      ShadowDepth="0"
                                      Color="{DynamicResource SidebarShadowColor}" />
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0"
                          Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="History"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                        <controls:AnimatedButton Grid.Column="1"
                                                 Style="{StaticResource FlatSidebarButtonStyle}"
                                                 Command="{Binding ClearHistoryCommand}"
                                                 Content="Clear history" />
                    </Grid>

                    <Grid Grid.Row="1">
                        <TextBlock Text="No saved calculations yet."
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   Visibility="{Binding History.IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}"
                                   VerticalAlignment="Top" />

                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      Visibility="{Binding History.HasEntries, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ItemsControl ItemsSource="{Binding History.Entries}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <controls:AnimatedButton Margin="0,0,0,10"
                                                                 Style="{StaticResource HistoryEntryButtonStyle}"
                                                                 Command="{Binding DataContext.LoadHistoryEntryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                 CommandParameter="{Binding}"
                                                                 Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                 ToolTip="Click to reuse. Right-click for more actions.">
                                            <controls:AnimatedButton.ContextMenu>
                                                <ContextMenu Style="{StaticResource HistoryContextMenuStyle}">
                                                    <MenuItem Header="Use expression"
                                                              Style="{StaticResource HistoryContextMenuItemStyle}"
                                                              Command="{Binding PlacementTarget.Tag.LoadHistoryEntryCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                    <MenuItem Header="Copy expression"
                                                              Style="{StaticResource HistoryContextMenuItemStyle}"
                                                              Command="{Binding PlacementTarget.Tag.CopyHistoryExpressionCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                    <MenuItem Header="Copy result"
                                                              Style="{StaticResource HistoryContextMenuItemStyle}"
                                                              Command="{Binding PlacementTarget.Tag.CopyHistoryResultCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                    <Separator Style="{StaticResource HistoryContextMenuSeparatorStyle}" />
                                                    <MenuItem Header="Delete entry"
                                                              Style="{StaticResource HistoryContextMenuItemStyle}"
                                                              Command="{Binding PlacementTarget.Tag.DeleteHistoryEntryCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                    <MenuItem Header="Clear all history"
                                                              Style="{StaticResource HistoryContextMenuItemStyle}"
                                                              Command="{Binding PlacementTarget.Tag.ClearHistoryCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                </ContextMenu>
                                            </controls:AnimatedButton.ContextMenu>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Expression}"
                                                           TextWrapping="Wrap"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Margin="0,8,0,0"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource ResultBrush}">
                                                    <Run Text="= " />
                                                    <Run Text="{Binding Result}" />
                                                </TextBlock>
                                                <TextBlock Text="{Binding Timestamp, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}"
                                                           Margin="0,8,0,0"
                                                           Foreground="{DynamicResource MutedTextBrush}" />
                                            </StackPanel>
                                        </controls:AnimatedButton>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
